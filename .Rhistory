# Run the code below before proceeding.
a_b_grid <- expand_grid(
a = c(0, 0.2, 0.4, 0.6, 0.8, 1),
b = c(0, 0.2, 0.4, 0.6, 0.8, 1),
t = seq(0, 100, by = 0.01)
)
a_b_grid <- a_b_grid |>
mutate(p = 1 - a * exp(-b * t)) |>
mutate(
a = as.factor(a),
b = as.factor(b)
)
levels(a_b_grid$a) <- c(
"a = 0", "a = 0.2", "a = 0.4",
"a = 0.6", "a = 0.8", "a = 1"
)
levels(a_b_grid$b) <- c(
"b = 0", "b = 0.2", "b = 0.4",
"b = 0.6", "b = 0.8", "b = 1"
)
a_b_plot <- ggplot() +
geom_line(
data = a_b_grid, aes(x = t, y = p),
color = "darkgreen"
) +
facet_grid(a ~ b) +
theme(
plot.title = element_text(size = 12, face = "bold"),
axis.text = element_text(size = 10),
axis.title = element_text(size = 10),
strip.text.x = element_text(size = 12),
strip.text.y = element_text(size = 12)
) +
ggtitle("Behaviour of a and b") +
labs(x = "Time Played (Hours)", y = "Probablity")
a_b_plot
